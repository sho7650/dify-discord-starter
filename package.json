{
  "name": "dify-discord-starter",
  "version": "0.0.5",
  "description": "A starter project to create discord bots with dify apps.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "install-cmd": "ts-node scripts/install.ts",
    "dev": "nodemon",
    "release": "standard-version",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "docker:push:test": "bash scripts/docker-push.sh test",
    "docker:push:prod": "bash scripts/docker-push.sh prod"
  },
  "author": "Pascal Malbranche",
  "license": "MIT",
  "dependencies": {
    "@discordjs/builders": "^1.7.0",
    "@discordjs/rest": "^2.2.0",
    "axios": "^1.6.5",
    "discord-api-types": "^0.37.120",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.2",
    "prettier": "3.2.5",
    "ts-node": "^10.9.2"
  }
}
